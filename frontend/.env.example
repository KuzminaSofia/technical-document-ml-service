# URL для API-запросов из браузера (через nginx, относительный путь)
NEXT_PUBLIC_API_URL=/api

# URL для API-запросов на стороне сервера Next.js (прямо в Docker-сети, без nginx)
INTERNAL_API_URL=http://app:8000

# Лимиты загрузки файлов — должны совпадать с APP_MAX_UPLOAD_FILE_SIZE_MB
# и APP_MAX_TASK_TOTAL_SIZE_MB на бэкенде
MAX_FILE_MB=50
MAX_TOTAL_MB=200
