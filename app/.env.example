APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

POSTGRES_DB=technical_document_service
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me

# Параметры пула соединений SQLAlchemy (опционально)
# DB_POOL_SIZE — базовое число постоянных соединений
# DB_MAX_OVERFLOW — доп. соединения сверх pool_size при пиковой нагрузке
# DB_POOL_TIMEOUT — секунд ожидания свободного соединения до ошибки PoolTimeout
# DB_POOL_RECYCLE — секунд до пересоздания соединения (защита от stale-соединений)
#DB_POOL_SIZE=5
#DB_MAX_OVERFLOW=10
#DB_POOL_TIMEOUT=30
#DB_POOL_RECYCLE=1800

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
# RABBITMQ_PREDICTION_QUEUE — очередь ML-задач (дефолт: technical_document_prediction_tasks)
# RABBITMQ_WEBHOOK_QUEUE    — очередь webhook-уведомлений (дефолт: technical_document_webhook_delivery)
#RABBITMQ_PREDICTION_QUEUE=technical_document_prediction_tasks
#RABBITMQ_WEBHOOK_QUEUE=technical_document_webhook_delivery

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_JWT_SECRET_KEY=change-me-generate-a-random-64-char-hex-string
APP_JWT_EXPIRE_MINUTES=60
APP_AUTH_COOKIE_NAME=tdms_access_token
# false — для локальной разработки по HTTP. В production: true
APP_AUTH_COOKIE_SECURE=false

APP_PASSWORD_PBKDF2_ITERATIONS=600000
APP_PASSWORD_SALT_BYTES=16

# Параметры воркеров (опционально)
# WORKER_RECONNECT_DELAY_SECONDS — пауза перед повторным подключением к RabbitMQ после потери соединения
# WORKER_TASK_TIMEOUT_SECONDS — максимальное время обработки одной ML-задачи (сек); при превышении — reject без requeue
#WORKER_RECONNECT_DELAY_SECONDS=5
#WORKER_TASK_TIMEOUT_SECONDS=600

# Transactional Outbox relay (опционально)
# APP_OUTBOX_POLL_INTERVAL_SECONDS — интервал опроса БД на предмет недоставленных задач (сек)
# Relay — механизм crash-recovery, а не fast path: задача в норме доставляется напрямую.
#APP_OUTBOX_POLL_INTERVAL_SECONDS=60
